{
  "name": "pdd-auto-reply",
  "productName": "多多尾巴",
  "version": "0.1.1",
  "description": "多多尾巴 · 拼多多客服自动回复工具",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "vue:build": "vite build",
    "vue:watch": "vite build --watch",
    "version:patch": "node tools/bump-version.js patch",
    "build:win:raw": "pnpm vue:build && electron-builder --win nsis --x64",
    "build:win": "pnpm version:patch && pnpm build:win:raw",
    "smoke:api": "electron test/run-pdd-api-smoke.js",
    "snapshot:api-traffic": "electron tools/snapshot-api-traffic.js",
    "rebuild:api-traffic-index": "electron tools/rebuild-api-traffic-index.js",
    "export:api-sample": "electron tools/export-api-traffic-sample.js",
    "analyze:api-traffic": "electron tools/analyze-api-traffic.js",
    "build:api-traffic-report": "electron tools/build-api-traffic-report.js",
    "refresh:api-traffic-artifacts": "electron tools/export-api-traffic-sample.js && electron tools/build-api-traffic-report.js"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.yuanweiba.pdd-auto-reply",
    "productName": "多多尾巴",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "test/pdd-qa-rules.json",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@huggingface/transformers": "^3.8.1",
    "electron-store": "8",
    "element-plus": "^2.13.7",
    "vue": "^3.5.32"
  }
}
